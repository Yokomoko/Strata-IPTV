<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      The Strata launch theme.  Compose owns 99% of the styling at runtime,
      but Android needs an XML theme on the activity for the splash window
      and for the system status / nav bar colours.
    -->
    <style name="Theme.StrataTV" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/strata_surface_void</item>
        <item name="android:colorBackground">@color/strata_surface_void</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
